{
  "name": "pitt_axes_scene",
  "version": 1,
  "units": "world",
  "description": "Scene hierarchy with Cartesian axes as the parent and a word parent spelling PITT with monospace glyph children.",
  "projection_preset": "assets/projections/plan_xy.projection.json",
  "nodes": [
    {
      "id": "axes_root",
      "type": "cartesian_axes",
      "geometry_asset": "assets/models/cartesian_axes.obj",
      "metadata_asset": "assets/cartesian_axes.json",
      "parent": null,
      "local_transform": {
        "translation": [
          0.0,
          0.0,
          0.0
        ],
        "rotation_degrees": [
          0.0,
          0.0,
          0.0
        ],
        "scale": [
          1.0,
          1.0,
          1.0
        ]
      },
      "display": {
        "visible": true,
        "show_labels": true
      }
    },
    {
      "id": "word_pitt",
      "type": "bezier_word",
      "word_asset": "assets/words/pitt.word.json",
      "metadata_asset": "assets/words/pitt.metadata.json",
      "parent": "axes_root",
      "local_transform": {
        "translation": [
          0.25,
          0.35,
          0.0
        ],
        "rotation_degrees": [
          0.0,
          0.0,
          0.0
        ],
        "scale": [
          0.85,
          0.85,
          0.85
        ]
      },
      "display": {
        "visible": true,
        "show_word_bounds": false,
        "show_glyphs": true
      }
    }
  ],
  "hierarchy": {
    "axes_root": [
      "word_pitt"
    ],
    "word_pitt": [
      "glyph_P_0",
      "glyph_I_1",
      "glyph_T_2",
      "glyph_T_3"
    ]
  }
}
