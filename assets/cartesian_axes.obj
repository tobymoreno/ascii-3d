# cartesian_axes.obj
# Shorter line-based Cartesian axes for the current shared scene scale.
# Geometry remains fully asset-driven.

o cartesian_axes

# Shared origin
v 0.0 0.0 0.0

# Positive axis endpoints
v 1.25 0.0 0.0
v 0.0 1.25 0.0
v 0.0 0.0 1.25

# X arrowhead points
v 1.05  0.08 0.0
v 1.05 -0.08 0.0

# Y arrowhead points
v  0.08 1.05 0.0
v -0.08 1.05 0.0

# Z arrowhead points
v  0.08 0.0 1.05
v -0.08 0.0 1.05

g x_axis
l 1 2
l 2 5
l 2 6

g y_axis
l 1 3
l 3 7
l 3 8

g z_axis
l 1 4
l 4 9
l 4 10
